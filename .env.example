# Docker环境变量配置文件
# 复制此文件为 .env 并根据需要修改配置

# MySQL配置
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=bico_admin
MYSQL_USER=bico_admin
MYSQL_PASSWORD=password
MYSQL_PORT=3306

# Redis配置
REDIS_PASSWORD=
REDIS_PORT=6379

# 后端配置
BACKEND_PORT=8080
JWT_SECRET=your-very-secure-jwt-secret-key-change-in-production

# 前端配置
FRONTEND_PORT=3000
