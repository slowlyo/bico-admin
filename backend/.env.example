# 服务器配置
PORT=8080
ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=bico_admin

# Redis配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your-secret-key
JWT_EXPIRE=24h

# 文件上传配置
UPLOAD_PATH=./storage/uploads
MAX_UPLOAD_SIZE=10MB

# 日志配置
LOG_LEVEL=info
LOG_PATH=./storage/logs

# 路由前缀配置
ADMIN_PREFIX=/admin
API_PREFIX=/api
